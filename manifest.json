{
  "manifest_version": 3,
  "name": "日本株/米国株 銘柄チェッカー",
  "version": "0.3.1",
  "description": "Cleartradeで利用する銘柄チェッカー。日本株/米国株向けです。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://jp.tradingview.com/chart/*"],
      "js": ["tradingview.js"],
      "run_at": "document_start"
    }
  ]
}